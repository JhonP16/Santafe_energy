# Configuración del backend (copiar a .env y ajustar si es necesario)

# URL base de la API pública de XM
XM_API_BASE_URL=https://servapibi.xm.com.co

# Timeout (segundos) para las peticiones a la API de XM
XM_API_TIMEOUT=60

# Orígenes permitidos para CORS (separados por coma)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
